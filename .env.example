# Example environment configuration for satsim.
# Copy to `.env` and uncomment to override run-level knobs.
# Precedence: CLI flag > .env / environment > scenario default.

# RNG seed for reproducibility.
# SATSIM_SEED=7

# Override the scenario's duration (number of time steps).
# SATSIM_STEPS=120

# Primary scheduler: heuristic | priority_fair | slot_mac | contention_mac
# SATSIM_SCHEDULER=priority_fair

# Tier-3 optimizer backend: heuristic | solver | adaptive
# SATSIM_OPTIMIZER_BACKEND=heuristic

# MILP solver time limit in seconds (only used when backend=solver).
# SATSIM_SOLVER_TIME_LIMIT_S=0.5

# Print per-step telemetry while running: true | false
# SATSIM_VERBOSE=false
